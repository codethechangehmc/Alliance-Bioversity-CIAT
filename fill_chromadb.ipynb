    "#!/usr/bin/env python3\n",
    "\"\"\"\n",
    "Robust PDF -> Table extraction using pdfplumber's low-level approach.\n",
    "Converts tables to Markdown, then uses OpenAI to convert to CSV.\n",
    "\"\"\"\n",
    "\n",
    "import os\n",
    "import re\n",
    "import sys\n",
    "from pathlib import Path\n",
    "from typing import List, Tuple\n",
    "\n",
    "import pdfplumber\n",
    "from openai import OpenAI\n",
    "\n",
    "# ---------- CONFIG ----------\n",
    "PDF_PATH = \"pdfs/bo1005-leketa-2019.pdf\"  # <-- your PDF\n",
    "OUT_DIR = Path(\"out_tables\")\n",
    "MODEL = \"gpt-4o-mini\"\n",
    "\n",
    "# Optional: load .env\n",
    "try:\n",
    "    from dotenv import load_dotenv\n",
    "    load_dotenv()\n",
    "except:\n",
    "    pass\n",
    "\n",
    "# ---------- TABLE EXTRACTION ----------\n",
    "\n",
    "def extract_tables_from_pdf(pdf_path: str) -> List[Tuple[int, str]]:\n",
    "    \"\"\"\n",
    "    Extract tables from PDF using pdfplumber.\n",
    "    Returns: List of (page_num, markdown_table_string) tuples\n",
    "    \"\"\"\n",
    "    tables_found = []\n",
    "    \n",
    "    with pdfplumber.open(pdf_path) as pdf:\n",
    "        for page_num, page in enumerate(pdf.pages, start=1):\n",
    "            print(f\"[INFO] Scanning page {page_num}...\")\n",
    "            \n",
    "            # Strategy 1: Use pdfplumber's built-in table extraction\n",
    "            try:\n",
    "                tables = page.extract_tables()\n",
    "                if tables:\n",
    "                    for table_idx, table in enumerate(tables):\n",
    "                        if table and len(table) > 1:  # Must have header + data\n",
    "                            md_table = table_to_markdown(table)\n",
    "                            if md_table:\n",
    "                                print(f\"  ✓ Found table {table_idx + 1} on page {page_num}\")\n",
    "                                tables_found.append((page_num, md_table))\n",
    "            except Exception as e:\n",
    "                print(f\"  ✗ Table extraction error on page {page_num}: {e}\")\n",
    "            \n",
    "            # Strategy 2: If no tables found, try with custom settings\n",
    "            if not tables:\n",
    "                try:\n",
    "                    tables = page.extract_tables(table_settings={\n",
    "                        \"vertical_strategy\": \"text\",\n",
    "                        \"horizontal_strategy\": \"text\",\n",
    "                        \"intersection_tolerance\": 15,\n",
    "                    })\n",
    "                    if tables:\n",
    "                        for table_idx, table in enumerate(tables):\n",
    "                            if table and len(table) > 1:\n",
    "                                md_table = table_to_markdown(table)\n",
    "                                if md_table:\n",
    "                                    print(f\"  ✓ Found table {table_idx + 1} on page {page_num} (alt strategy)\")\n",
    "                                    tables_found.append((page_num, md_table))\n",
    "                except Exception as e:\n",
    "                    print(f\"  ✗ Alt strategy error on page {page_num}: {e}\")\n",
    "    \n",
    "    return tables_found\n",
    "\n",
    "\n",
    "def table_to_markdown(table: List[List]) -> str:\n",
    "    \"\"\"\n",
    "    Convert a pdfplumber table (list of lists) to GitHub-flavored Markdown.\n",
    "    \"\"\"\n",
    "    if not table or len(table) < 2:\n",
    "        return \"\"\n",
    "    \n",
    "    # Clean cells\n",
    "    cleaned = []\n",
    "    for row in table:\n",
    "        cleaned_row = []\n",
    "        for cell in row:\n",
    "            if cell is None:\n",
    "                cleaned_row.append(\"\")\n",
    "            else:\n",
    "                # Clean up whitespace\n",
    "                cleaned_cell = re.sub(r'\\s+', ' ', str(cell).strip())\n",
    "                cleaned_row.append(cleaned_cell)\n",
    "        cleaned.append(cleaned_row)\n",
    "    \n",
    "    # Ensure all rows have same number of columns\n",
    "    max_cols = max(len(row) for row in cleaned)\n",
    "    for row in cleaned:\n",
    "        while len(row) < max_cols:\n",
    "            row.append(\"\")\n",
    "    \n",
    "    # Build markdown\n",
    "    lines = []\n",
    "    \n",
    "    # Header row\n",
    "    header = cleaned[0]\n",
    "    lines.append(\"| \" + \" | \".join(header) + \" |\")\n",
    "    \n",
    "    # Separator row\n",
    "    lines.append(\"| \" + \" | \".join([\"---\"] * len(header)) + \" |\")\n",
    "    \n",
    "    # Data rows\n",
    "    for row in cleaned[1:]:\n",
    "        lines.append(\"| \" + \" | \".join(row) + \" |\")\n",
    "    \n",
    "    return \"\\n\".join(lines)\n",
    "\n",
    "\n",
    "# ---------- OPENAI CONVERSION ----------\n",
    "\n",
    "def get_openai_client() -> OpenAI:\n",
    "    \"\"\"Get OpenAI client with API key from environment.\"\"\"\n",
    "    key = os.getenv(\"OPENAI_API_KEY\")\n",
    "    if not key:\n",
    "        raise RuntimeError(\n",
    "            \"OPENAI_API_KEY not found. Set it with:\\n\"\n",
    "            \"  export OPENAI_API_KEY='your-key-here'\"\n",
    "        )\n",
    "    return OpenAI(api_key=key)\n",
    "\n",
    "\n",
    "def markdown_to_csv(md_table: str, client: OpenAI) -> str:\n",
    "    \"\"\"\n",
    "    Convert a Markdown table to CSV using OpenAI.\n",
    "    \"\"\"\n",
    "    system_prompt = (\n",
    "        \"You are a data conversion assistant. Convert GitHub-flavored Markdown tables \"\n",
    "        \"into clean CSV format. Preserve all data exactly. Return ONLY the CSV text \"\n",
    "        \"with no explanations, no code blocks, no markdown formatting.\"\n",
    "    )\n",
    "    \n",
    "    user_prompt = (\n",
    "        \"Convert this Markdown table to CSV format. \"\n",
    "        \"Keep the header row and all data rows. \"\n",
    "        \"If cells contain commas, wrap them in quotes.\\n\\n\"\n",
    "        f\"{md_table}\"\n",
    "    )\n",
    "    \n",
    "    response = client.chat.completions.create(\n",
    "        model=MODEL,\n",
    "        temperature=0,\n",
    "        messages=[\n",
    "            {\"role\": \"system\", \"content\": system_prompt},\n",
    "            {\"role\": \"user\", \"content\": user_prompt}\n",
    "        ]\n",
    "    )\n",
    "    \n",
    "    csv_text = response.choices[0].message.content.strip()\n",
    "    \n",
    "    # Remove any accidental code fences\n",
    "    csv_text = re.sub(r'^```[a-z]*\\n?', '', csv_text)\n",
    "    csv_text = re.sub(r'\\n?```$', '', csv_text)\n",
    "    \n",
    "    return csv_text\n",
    "\n",
    "\n",
    "# ---------- MAIN ----------\n",
    "\n",
    "def main():\n",
    "    # Validate inputs\n",
    "    pdf_path = Path(PDF_PATH)\n",
    "    if not pdf_path.exists():\n",
    "        print(f\"[ERROR] PDF not found: {pdf_path}\")\n",
    "        sys.exit(1)\n",
    "    \n",
    "    OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "    \n",
    "    # Extract tables\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"Processing: {pdf_path.name}\")\n",
    "    print(f\"{'='*60}\\n\")\n",
    "    \n",
    "    tables = extract_tables_from_pdf(str(pdf_path))\n",
    "    \n",
    "    if not tables:\n",
    "        print(\"\\n[WARNING] No tables found in PDF!\")\n",
    "        print(\"\\nTroubleshooting tips:\")\n",
    "        print(\"1. Verify your PDF contains actual tables (not just text)\")\n",
    "        print(\"2. Check if the PDF is scanned (may need OCR)\")\n",
    "        print(\"3. Try opening the PDF to see if tables are selectable\")\n",
    "        return\n",
    "    \n",
    "    print(f\"\\n[SUCCESS] Found {len(tables)} table(s)\\n\")\n",
    "    \n",
    "    # Get OpenAI client\n",
    "    try:\n",
    "        client = get_openai_client()\n",
    "    except RuntimeError as e:\n",
    "        print(f\"[ERROR] {e}\")\n",
    "        sys.exit(1)\n",
    "    \n",
    "    # Convert tables to CSV\n",
    "    for idx, (page_num, md_table) in enumerate(tables, start=1):\n",
    "        print(f\"{'─'*60}\")\n",
    "        print(f\"Table {idx} (from page {page_num})\")\n",
    "        print(f\"{'─'*60}\")\n",
    "        \n",
    "        # Save markdown version\n",
    "        md_path = OUT_DIR / f\"{pdf_path.stem}_table_{idx:02d}_p{page_num}.md\"\n",
    "        md_path.write_text(md_table, encoding=\"utf-8\")\n",
    "        print(f\"✓ Saved Markdown: {md_path.name}\")\n",
    "        \n",
    "        # Preview markdown\n",
    "        print(\"\\nMarkdown preview:\")\n",
    "        preview_lines = md_table.split('\\n')[:5]\n",
    "        for line in preview_lines:\n",
    "            print(f\"  {line}\")\n",
    "        if len(md_table.split('\\n')) > 5:\n",
    "            print(\"  ...\")\n",
    "        \n",
    "        # Convert to CSV\n",
    "        print(f\"\\n→ Converting to CSV via OpenAI...\")\n",
    "        try:\n",
    "            csv_text = markdown_to_csv(md_table, client)\n",
    "            \n",
    "            # Save CSV\n",
    "            csv_path = OUT_DIR / f\"{pdf_path.stem}_table_{idx:02d}_p{page_num}.csv\"\n",
    "            csv_path.write_text(csv_text, encoding=\"utf-8\")\n",
    "            print(f\"✓ Saved CSV: {csv_path.name}\")\n",
    "            \n",
    "            # Preview CSV\n",
    "            print(\"\\nCSV preview:\")\n",
    "            csv_lines = csv_text.split('\\n')[:5]\n",
    "            for line in csv_lines:\n",
    "                print(f\"  {line}\")\n",
    "            if len(csv_text.split('\\n')) > 5:\n",
    "                print(\"  ...\")\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"✗ Error converting to CSV: {e}\")\n",
    "        \n",
    "        print()\n",
    "    \n",
    "    print(f\"{'='*60}\")\n",
    "    print(f\"✓ Complete! Check {OUT_DIR}/ for output files\")\n",
    "    print(f\"{'='*60}\\n\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
   ]
