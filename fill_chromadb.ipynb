    "# === helpers: put this cell ABOVE your main loop cell ===\n",
    "# Deps: pip install pdfplumber pandas numpy tabulate openai python-dotenv\n",
    "\n",
    "import os, re\n",
    "from pathlib import Path\n",
    "from typing import List, Dict, Any, Optional\n",
    "\n",
    "import pdfplumber\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from tabulate import tabulate\n",
    "from openai import OpenAI\n",
    "\n",
    "# ---------- key loader (uses .env if present) ----------\n",
    "def get_openai_key_from_env(override: Optional[str] = None) -> str:\n",
    "    \"\"\"\n",
    "    Returns an OpenAI key. If an override is provided, use it.\n",
    "    Else, load from environment (supports .env via python-dotenv if user already called load_dotenv()).\n",
    "    \"\"\"\n",
    "    if override: \n",
    "        return override\n",
    "    key = os.getenv(\"OPENAI_API_KEY\")\n",
    "    if not key:\n",
    "        raise RuntimeError(\"OPENAI_API_KEY not found in environment. If it's in .env, call `from dotenv import load_dotenv; load_dotenv()` first.\")\n",
    "    return key\n",
    "\n",
    "# ---------- small utils ----------\n",
    "def _clean_cell(x) -> str:\n",
    "    if x is None:\n",
    "        return \"\"\n",
    "    s = re.sub(r\"\\s+\", \" \", str(x)).strip()\n",
    "    return s\n",
    "\n",
    "def _rows_to_dataframe(rows: List[List[str]]) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Heuristic DF maker:\n",
    "    - pad uneven rows\n",
    "    - pick first non-empty row as header\n",
    "    \"\"\"\n",
    "    if not rows:\n",
    "        return pd.DataFrame()\n",
    "    cleaned = [[_clean_cell(c) for c in r] for r in rows]\n",
    "    max_cols = max(len(r) for r in cleaned)\n",
    "    padded = [r + [\"\"] * (max_cols - len(r)) for r in cleaned]\n",
    "\n",
    "    header_idx = 0\n",
    "    for i, r in enumerate(padded):\n",
    "        if any(c for c in r):\n",
    "            header_idx = i\n",
    "            break\n",
    "    header = [c if c else f\"Column {j+1}\" for j, c in enumerate(padded[header_idx])]\n",
    "    data = padded[header_idx + 1:] if header_idx + 1 < len(padded) else []\n",
    "    return pd.DataFrame(data, columns=header)\n",
    "\n",
    "def _df_to_markdown(df: pd.DataFrame) -> str:\n",
    "    if df.empty:\n",
    "        return \"| |\\n|---|\\n| |\\n\"\n",
    "    return tabulate(df, headers=\"keys\", tablefmt=\"github\", showindex=False)\n",
    "\n",
    "# ---------- primary: pdfplumber smart extraction ----------\n",
    "def extract_tables_via_pdfplumber_smart(\n",
    "    pdf_path: str,\n",
    "    max_pages: Optional[int] = None,\n",
    ") -> List[Dict[str, Any]]:\n",
    "    \"\"\"\n",
    "    Try multiple pdfplumber strategies; if none found, fallback to a word-grid heuristic.\n",
    "    Returns list of dicts: [{\"page\": int, \"table_index\": int, \"markdown\": str, \"dataframe\": pd.DataFrame}, ...]\n",
    "    \"\"\"\n",
    "    out: List[Dict[str, Any]] = []\n",
    "\n",
    "    # strategies to try in order\n",
    "    strategies = [\n",
    "        # 1) lines-based (works when tables have ruling lines)\n",
    "        dict(vertical_strategy=\"lines\", horizontal_strategy=\"lines\", intersection_tolerance=5, snap_tolerance=3, join_tolerance=3, edge_min_length=3, keep_blank_chars=True),\n",
    "        # 2) text-based (works when tables are aligned but no lines)\n",
    "        dict(vertical_strategy=\"text\", horizontal_strategy=\"text\", text_tolerance=2, keep_blank_chars=True),\n",
    "        # 3) tuned lines/text hybrid (looser tolerances)\n",
    "        dict(vertical_strategy=\"lines\", horizontal_strategy=\"text\", text_tolerance=3, intersection_tolerance=7, keep_blank_chars=True),\n",
    "    ]\n",
    "\n",
    "    with pdfplumber.open(pdf_path) as pdf:\n",
    "        n_pages = len(pdf.pages)\n",
    "        limit = min(n_pages, max_pages) if max_pages else n_pages\n",
    "\n",
    "        for pno in range(limit):\n",
    "            page = pdf.pages[pno]\n",
    "            page_tables: List[pd.DataFrame] = []\n",
    "\n",
    "            # try pdfplumber built-ins\n",
    "            for s in strategies:\n",
    "                try:\n",
    "                    tables = page.extract_tables(table_settings=s) or []\n",
    "                except Exception:\n",
    "                    tables = []\n",
    "                for rows in tables:\n",
    "                    df = _rows_to_dataframe(rows)\n",
    "                    if not df.empty:\n",
    "                        page_tables.append(df)\n",
    "\n",
    "                # if we already got some tables for this page, stop trying more strategies\n",
    "                if page_tables:\n",
    "                    break\n",
    "\n",
    "            # fallback: word-grid heuristic (no external engines, no API)\n",
    "            if not page_tables:\n",
    "                df_grid = _extract_table_by_word_grid(page)\n",
    "                if df_grid is not None and not df_grid.empty:\n",
    "                    page_tables.append(df_grid)\n",
    "\n",
    "            # package results\n",
    "            for ti, df in enumerate(page_tables):\n",
    "                out.append({\n",
    "                    \"page\": pno + 1,\n",
    "                    \"table_index\": ti,\n",
    "                    \"markdown\": _df_to_markdown(df),\n",
    "                    \"dataframe\": df,\n",
    "                })\n",
    "    return out\n",
    "\n",
    "def _extract_table_by_word_grid(page) -> Optional[pd.DataFrame]:\n",
    "    \"\"\"\n",
    "    Heuristic: reconstruct a table from words by grouping them into rows by y-overlap and splitting into cells by big x-gaps.\n",
    "    This is intentionally simple & robust; it won’t be perfect, but often pulls usable tables when built-ins fail.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        words = page.extract_words(keep_blank_chars=True, use_text_flow=True, extra_attrs=[\"x0\",\"x1\",\"top\",\"bottom\"])\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "    if not words:\n",
    "        return None\n",
    "\n",
    "    # sort by vertical, then horizontal\n",
    "    words = sorted(words, key=lambda w: (w[\"top\"], w[\"x0\"]))\n",
    "    y_tol = 4  # points; merge words into same row if vertical distance within this\n",
    "    rows = []\n",
    "    current_row = []\n",
    "    current_top = None\n",
    "    current_bottom = None\n",
    "\n",
    "    for w in words:\n",
    "        w_top, w_bottom = w[\"top\"], w[\"bottom\"]\n",
    "        if current_row and not (w_top <= (current_bottom + y_tol) and w_bottom >= (current_top - y_tol)):\n",
    "            # commit row, start new\n",
    "            rows.append(current_row)\n",
    "            current_row = [w]\n",
    "            current_top, current_bottom = w_top, w_bottom\n",
    "        else:\n",
    "            # same row\n",
    "            current_row.append(w)\n",
    "            if current_top is None:\n",
    "                current_top, current_bottom = w_top, w_bottom\n",
    "            else:\n",
    "                current_top = min(current_top, w_top)\n",
    "                current_bottom = max(current_bottom, w_bottom)\n",
    "    if current_row:\n",
    "        rows.append(current_row)\n",
    "\n",
    "    if not rows:\n",
    "        return None\n",
    "\n",
    "    # convert each row of words to cells using x-gaps\n",
    "    # estimate a gap threshold from typical word widths\n",
    "    widths = [w[\"x1\"] - w[\"x0\"] for w in words]\n",
    "    if not widths:\n",
    "        return None\n",
    "    median_width = float(np.median(widths))\n",
    "    gap_threshold = median_width * 2.5  # tweakable\n",
    "\n",
    "    table_rows: List[List[str]] = []\n",
    "    for row in rows:\n",
    "        row = sorted(row, key=lambda w: w[\"x0\"])\n",
    "        cells = []\n",
    "        if not row:\n",
    "            table_rows.append([\"\"])\n",
    "            continue\n",
    "        # start first cell\n",
    "        current_cell_words = [row[0][\"text\"]]\n",
    "        for i in range(1, len(row)):\n",
    "            prev, cur = row[i-1], row[i]\n",
    "            gap = cur[\"x0\"] - prev[\"x1\"]\n",
    "            if gap > gap_threshold:\n",
    "                # new cell\n",
    "                cells.append(\" \".join(current_cell_words).strip())\n",
    "                current_cell_words = [cur[\"text\"]]\n",
    "            else:\n",
    "                current_cell_words.append(cur[\"text\"])\n",
    "        # last cell\n",
    "        cells.append(\" \".join(current_cell_words).strip())\n",
    "        table_rows.append(cells)\n",
    "\n",
    "    df = _rows_to_dataframe(table_rows)\n",
    "    # very short or 1-col tables are often false positives; keep them but they may be refined by GPT\n",
    "    return df\n",
    "\n",
    "# ---------- GPT: Markdown -> CSV (kept minimal) ----------\n",
    "def gpt_markdown_table_to_csv(\n",
    "    md_table: str,\n",
    "    OPENAI_API_KEY: Optional[str] = None,\n",
    "    model: str = \"gpt-4o-mini\",\n",
    ") -> str:\n",
    "    \"\"\"\n",
    "    Convert ONE Markdown table snippet → CSV (token-lean). Uses OPENAI_API_KEY.\n",
    "    \"\"\"\n",
    "    key = get_openai_key_from_env(override=OPENAI_API_KEY)\n",
    "    client = OpenAI(api_key=key)\n",
    "\n",
    "    snippet = md_table[:48000]  # safety cap\n",
    "    system_msg = (\n",
    "        \"You convert GitHub-flavored Markdown tables into clean CSV. \"\n",
    "        \"Keep the same header semantics and row order. \"\n",
    "        \"Return ONLY the CSV text—no commentary or code fences.\"\n",
    "    )\n",
    "    user_msg = (\n",
    "        \"Convert the following Markdown table to CSV with a single header row. \"\n",
    "        \"Join multi-line cells with a single space; leave empty cells blank.\\n\\n\"\n",
    "        f\"{snippet}\"\n",
    "    )\n",
    "    resp = client.chat.completions.create(\n",
    "        model=model,\n",
    "        temperature=0,\n",
    "        messages=[\n",
    "            {\"role\": \"system\", \"content\": system_msg},\n",
    "            {\"role\": \"user\", \"content\": user_msg},\n",
    "        ],\n",
    "    )\n",
    "    csv_text = resp.choices[0].message.content.strip()\n",
    "    csv_text = re.sub(r\"^\\s*```[a-zA-Z]*\\s*|\\s*```\\s*$\", \"\", csv_text, flags=re.S)\n",
    "    if not csv_text:\n",
    "        raise RuntimeError(\"OpenAI returned empty CSV text—inspect the table snippet or model.\")\n",
    "    return csv_text\n"
   ]
